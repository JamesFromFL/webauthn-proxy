{
  "manifest_version": 2,
  "name": "MyKey Proxy",
  "version": "0.1.0",
  "description": "MyKey hardware-backed WebAuthn proxy for Firefox. Awaiting Firefox platform authenticator API support.",
  "author": "JamesFromFL",
  "homepage_url": "https://github.com/JamesFromFL/mykey",
  "background": {
    "scripts": ["src/background.js"],
    "persistent": false
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "mykey-proxy@jamesfromfl",
      "strict_min_version": "109.0"
    }
  }
}
