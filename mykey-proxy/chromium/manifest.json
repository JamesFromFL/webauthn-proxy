{
  "manifest_version": 3,
  "name": "MyKey Proxy",
  "version": "0.1.0",
  "description": "Bridges WebAuthn platform authenticator requests to Linux PAM + TPM2 authentication",
  "permissions": [
    "webAuthenticationProxy",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
