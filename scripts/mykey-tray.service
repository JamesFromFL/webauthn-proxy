[Unit]
Description=MyKey System Tray
After=graphical-session.target mykey-daemon.service
Wants=mykey-daemon.service

[Service]
Type=simple
ExecStart=/usr/local/bin/mykey-tray
Restart=on-failure
RestartSec=3s
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=graphical-session.target
