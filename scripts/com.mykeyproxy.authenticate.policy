<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
  <vendor>MyKey Proxy</vendor>
  <vendor_url>https://github.com/JamesFromFL/mykey-proxy</vendor_url>

  <action id="com.mykeyproxy.authenticate">
    <description>Authenticate with MyKey Proxy</description>
    <message>MyKey Proxy needs to verify your identity before completing authentication.</message>
    <icon_name>security-high</icon_name>
    <annotate key="org.freedesktop.policykit.owner">unix-user:mykey-proxy</annotate>
    <defaults>
      <allow_any>auth_self</allow_any>
      <allow_inactive>auth_self</allow_inactive>
      <allow_active>auth_self</allow_active>
    </defaults>
  </action>
</policyconfig>
